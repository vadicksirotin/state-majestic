generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id             String        @id @default(uuid())
  discordId      String?       @unique
  name           String
  avatar         String?
  roles          UserRole[]
  applications   Application[]
  rosterEntries  RosterEntry[]
  createdAt      DateTime      @default(now())
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  factionId String   
  roleLevel String   
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, factionId])
}

model Application {
  id        String   @id @default(uuid())
  userId    String
  factionId String   
  status    String   @default("pending")
  formData  String   
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RosterEntry {
  id         String   @id @default(uuid())
  userId     String
  factionId  String   
  rank       String   
  rankWeight Int      @default(1) // Чем выше, тем значимее (например 1-15).
  department String?  
  status     String   @default("active") 
  joinedAt   DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Гранулярные права в формате JSON (например: '["edit_charter", "manage_departments"]')
  permissions String  @default("[]")

  @@unique([userId, factionId])
}

model NewsPost {
  id        String   @id @default(uuid())
  factionId String   
  title     String
  content   String
  imageUrl  String?
  tags      String 
  createdAt DateTime @default(now())
}

model FactionSettings {
  id               String @id @default(uuid())
  factionId        String @unique
  highCommandRank  Int    @default(10) // Минимальный rankWeight для статуса "Хай-ранг"
  leaderRank       Int    @default(15)
  charterText      String? // Устав фракции
}

model Department {
  id          String   @id @default(uuid())
  factionId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
}

model ItemRequest {
  id          String   @id @default(uuid())
  requesterId String   // User ID
  factionId   String
  itemName    String   // Что запрашивают (Снайперка, Дрон и т.д.)
  amount      Int      @default(1)
  reason      String
  status      String   @default("pending") // pending, approved, rejected
  reviewedBy  String?  // Имя того, кто рассмотрел
  createdAt   DateTime @default(now())
}

model PromotionReport {
  id          String   @id @default(uuid())
  reporterId  String   // User ID
  factionId   String
  content     String   // Ссылки на док-ва проделанной работы
  status      String   @default("pending")
  reviewedBy  String?
  createdAt   DateTime @default(now())
}

model Reprimand {
  id          String   @id @default(uuid())
  userId      String   // Кому выдали
  factionId   String
  issuerId    String   // Кто выдал (User ID)
  reason      String
  type        String   @default("verbal") // verbal (устный), written (строгий)
  isActive    Boolean  @default(true) // Можно снять выговор
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  factionId String
  action    String   // e.g. "ACCEPTED_APP", "FIRED_MEMBER", "PUBLISHED_NEWS"
  details   String   // JSON string or plain text description
  actorId   String   // User who did it
  createdAt DateTime @default(now())
}
